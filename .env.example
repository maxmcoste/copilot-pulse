# --- GitHub Auth: choose ONE mode ---

# Option A: Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# Option B: GitHub App (recommended for Copilot metrics)
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=7890123
# GITHUB_APP_PRIVATE_KEY_PATH=./copilot-pulse-app.private-key.pem
# or inline (escape newlines as \n):
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub org / enterprise
GITHUB_ENTERPRISE=my-enterprise-slug
GITHUB_ORG=my-org-name
GITHUB_API_VERSION=2026-03-10

# Anthropic (for the AI agent)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# App
CACHE_TTL_HOURS=6
WEB_PORT=8501
LOG_LEVEL=INFO
USE_LEGACY_API=false
